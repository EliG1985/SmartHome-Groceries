{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "install-backend-deps",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"apps/backend",
				"install"
			],
			"isBackground": false
		},
		{
			"label": "build-frontend-once",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build",
				"--workspace",
				"@smarthome/frontend"
			],
			"isBackground": false
		}
	]
}